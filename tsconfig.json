{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "types": [
            "node",
            "@wdio/globals/types",
            "@wdio/mocha-framework",
            "mocha",
            "@wdio/types"
        ],
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "outDir": "./dist"
    },
    "include": [
        "tests/**/*.ts",
        "pages/**/*.ts",
        "utils/**/*.ts",
        "config/**/*.ts",
        "wdio.conf.ts"
    ]
}